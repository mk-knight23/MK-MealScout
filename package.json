{
  "name": "17-web-culinary-discovery",
  "private": true,
  "version": "2.1.0",
  "type": "module",
  "scripts": {
    "production": "npm run build && npm start",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .vue,.ts,.tsx",
    "lint:fix": "eslint src --ext .vue,.ts,.tsx --fix",
    "format": "prettier --write .",
    "typecheck": "vue-tsc -b && vite build"
  },
  "dependencies": {
    "@vueuse/core": "^14.1.0",
    "lucide-vue-next": "^0.563.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.24",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "autoprefixer": "^10.4.20",
    "eslint-plugin-vue": "^9",
    "happy-dom": "^20.4.0",
    "jsdom": "^27.4.0",
    "postcss": "^8.4.49",
    "prettier": "^3",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.2.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.1.4"
  }
