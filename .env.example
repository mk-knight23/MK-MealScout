# MK MealScout — Environment Variables
# Copy this file to .env.local for local dev, or set these in the Vercel project.
# All variables are optional.

# TheMealDB base URL. Override to point at a mirror or a mock during testing.
VITE_MEALDB_API_BASE=https://www.themealdb.com/api/json/v1/1

# --- Analytics (optional, per docs/ANALYTICS.md) ---
VITE_GTM_ID=
VITE_GA4_ID=

# --- AI (not wired yet; placeholders for future work) ---
# AI_PROVIDER=openai|anthropic|google
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
